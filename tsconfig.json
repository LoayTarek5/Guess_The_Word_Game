{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "types/**/*.ts",
    "controllers/**/*.ts",
    "socket/**/*.ts",
    "utils/**/*.ts",
    "routes/**/*.ts",
    "public/ts/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
